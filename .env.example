# ===========================
#  GitCanvas — Environment Variables
# ===========================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.

# GitHub Personal Access Token (free)
# Get yours: GitHub → Settings → Developer Settings → Personal Access Tokens → Fine-grained tokens
# Select "Public Repositories (read-only)" — no special scopes needed
GITHUB_TOKEN=your_github_pat_here

# Gemini API Key (free tier — zero cost)
# Get yours: https://aistudio.google.com/apikey — no credit card needed
GEMINI_API_KEY=your_gemini_api_key_here
